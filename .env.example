# Application 
UNET_APP_NAME="UNet Segmentation Pipeline"
UNET_DEBUG=false

# Google Drive (only needed when UNET_DATA_MODE=online)
# Path to YOUR OWN Google service-account JSON. Keep it out of git (already in .gitignore).
UNET_GOOGLE_CREDENTIALS_PATH=credentials.json
# ID of YOUR OWN Google Drive root folder (see README "Data Modes" for the expected structure).
UNET_BASE_FOLDER_ID=your-google-drive-folder-id

# Model 
UNET_MODEL_SAVE_PATH=u_net.pth
UNET_N_CHANNELS=3
UNET_N_CLASSES=2

# Training 
UNET_BATCH_SIZE=2
UNET_LEARNING_RATE=0.001
UNET_NUM_EPOCHS=20
UNET_NUM_WORKERS=2

# Data
# "local" (read tiles from disk, no credentials) or "online" (stream from Google Drive).
UNET_DATA_MODE=local
UNET_LOCAL_DATA_DIR=data

# Output / Save
UNET_ANTHILL_SAVE_THRESHOLD=40.0

# Pixel Segmentation Threshold
UNET_ANTHILL_CONFIDENCE_THRESHOLD=0.40

# Region Filter
UNET_USE_REGION_FILTER=true
UNET_MIN_ANTHILL_REGION_PX=5
UNET_MAX_ANTHILL_REGION_PX=5000

UNET_CLASS_WEIGHT_ANTHILL=6.0
UNET_CLASS_WEIGHT_BACKGROUND=1.0